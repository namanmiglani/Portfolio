		<script>
			/* ── Tab switching ───────────────────────────────── */
			const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
			const panels = document.querySelectorAll<HTMLElement>('[data-tab-panel]');
			let resumeOpened = false;

			const setActiveTab = (tabKey: string) => {
				tabs.forEach(tab => tab.classList.toggle('active', tab.dataset.tab === tabKey));
				panels.forEach(panel => panel.classList.toggle('active', panel.dataset.tabPanel === tabKey));
				if (tabKey === 'resume' && !resumeOpened) {
					window.open('/resume.pdf', '_blank');
					resumeOpened = true;
				}
			};

			tabs.forEach(tab =>
				tab.addEventListener('click', () => {
					const tabKey = tab.dataset.tab || 'about';
					setActiveTab(tabKey);
					const targetId = tab.dataset.target;
					if (targetId) {
						const target = document.getElementById(targetId);
						if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
					}
				})
			);

			setActiveTab('about');

			/* ── Expandable experience details ───────────────── */
			document.querySelectorAll('.experience-item').forEach(item => {
				const details = item.querySelector('.exp-details');
				if (!details) return;
				(details as HTMLElement).style.display = 'none';
				const btn = document.createElement('button');
				btn.className = 'more-btn';
				btn.textContent = 'more details ↓';
				btn.addEventListener('click', () => {
					const open = (details as HTMLElement).style.display !== 'none';
					(details as HTMLElement).style.display = open ? 'none' : 'block';
					btn.textContent = open ? 'more details ↓' : 'less details ↑';
				});
				item.appendChild(btn);
			});

			/* ── Mouse-tracking dot particles ────────────────── */
			interface Dot {
				x: number; y: number;
				size: number;
				color: string;
				vx: number; vy: number;
				life: number; maxLife: number;
			}

			const canvas = document.getElementById('dot-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;
			const COLORS = ['#e74c3c', '#3498db', '#2ecc71', '#f39c12', '#9b59b6', '#1abc9c'];
			const dots: Dot[] = [];
			let mouseX = -1000, mouseY = -1000;

			function resize() {
				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;
			}
			resize();
			window.addEventListener('resize', resize);

			window.addEventListener('mousemove', (e: MouseEvent) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				// Only spawn dots while hovering in the hero section
				const hero = document.querySelector('.hero') as HTMLElement;
				if (!hero) return;
				const rect = hero.getBoundingClientRect();
				if (e.clientY < rect.bottom + 20) {
					for (let i = 0; i < 2; i++) {
						const size = 4 + Math.random() * 5;
						dots.push({
							x: e.clientX + (Math.random() - 0.5) * 20,
							y: e.clientY + (Math.random() - 0.5) * 20,
							size,
							color: COLORS[Math.floor(Math.random() * COLORS.length)],
							vx: (Math.random() - 0.5) * 1.2,
							vy: (Math.random() - 0.5) * 1.2 - 0.5,
							life: 0,
							maxLife: 60 + Math.random() * 60,
						});
					}
				}
			});

			function animateDots() {
				ctx.clearRect(0, 0, canvas.width, canvas.height);
				for (let i = dots.length - 1; i >= 0; i--) {
					const d = dots[i];
					d.x += d.vx;
					d.y += d.vy;
					d.life++;
					const alpha = 1 - d.life / d.maxLife;
					if (alpha <= 0) { dots.splice(i, 1); continue; }
					ctx.globalAlpha = alpha;
					ctx.fillStyle = d.color;
					ctx.fillRect(d.x - d.size / 2, d.y - d.size / 2, d.size, d.size);
				}
				ctx.globalAlpha = 1;
				requestAnimationFrame(animateDots);
			}
			animateDots();
		</script>
