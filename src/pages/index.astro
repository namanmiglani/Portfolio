		<script>
			/* ── Sidebar highlight on scroll ─────────────────── */
			const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar-link');
			const sections = document.querySelectorAll<HTMLElement>('[id]');

			const observerOpts = { rootMargin: '-20% 0px -60% 0px' };
			const sectionObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const id = entry.target.id;
						sidebarLinks.forEach(link => {
							link.classList.toggle('active', link.dataset.section === id);
						});
					}
				});
			}, observerOpts);

			document.querySelectorAll('.ide__scroll-area [id]').forEach(el => sectionObserver.observe(el));

			/* ── Expandable details (experience + projects) ──── */
			document.querySelectorAll('.experience-item, .project-entry').forEach(item => {
				const details = item.querySelector('.exp-details') as HTMLElement | null;
				if (!details) return;
				details.style.display = 'none';
				const btn = document.createElement('button');
				btn.className = 'more-btn';
				btn.textContent = 'more details ↓';
				btn.addEventListener('click', () => {
					const open = details.style.display !== 'none';
					details.style.display = open ? 'none' : 'block';
					btn.textContent = open ? 'more details ↓' : 'less details ↑';
				});
				// Insert button after the details
				details.parentNode!.insertBefore(btn, details.nextSibling);
			});

			/* ── Pin Board — Draggable Cards ──────────────── */
			(function initPinBoard() {
				const board = document.getElementById('pin-board');
				if (!board) return;
				const cards = board.querySelectorAll<HTMLElement>('.pin-card');
				let topZ = 10;

				// Apply initial rotations from data attribute
				cards.forEach(card => {
					const rot = card.dataset.rotate || '0';
					card.style.transform = `rotate(${rot}deg)`;
				});

				// Skip drag on small screens
				if (window.innerWidth < 768) return;

				let dragCard: HTMLElement | null = null;
				let offsetX = 0, offsetY = 0;
				let savedRotation = '';

				function startDrag(card: HTMLElement, clientX: number, clientY: number) {
					dragCard = card;
					const rect = card.getBoundingClientRect();
					offsetX = clientX - rect.left;
					offsetY = clientY - rect.top;
					savedRotation = card.dataset.rotate || '0';
					topZ++;
					card.style.zIndex = String(topZ);
					card.classList.add('dragging');
				}

				function moveDrag(clientX: number, clientY: number) {
					if (!dragCard || !board) return;
					const boardRect = board.getBoundingClientRect();
					let newLeft = clientX - boardRect.left - offsetX;
					let newTop = clientY - boardRect.top - offsetY;

					// Constrain within board
					const maxLeft = board.clientWidth - dragCard.offsetWidth;
					const maxTop = board.clientHeight - dragCard.offsetHeight;
					newLeft = Math.max(0, Math.min(newLeft, maxLeft));
					newTop = Math.max(0, Math.min(newTop, maxTop));

					dragCard.style.left = newLeft + 'px';
					dragCard.style.top = newTop + 'px';
				}

				function endDrag() {
					if (!dragCard) return;
					dragCard.classList.remove('dragging');
					dragCard.style.transform = `rotate(${savedRotation}deg)`;
					dragCard = null;
				}

				// Mouse events
				cards.forEach(card => {
					card.addEventListener('mousedown', (e: MouseEvent) => {
						// Don't drag if clicking inside the Spotify iframe
						if ((e.target as HTMLElement).tagName === 'IFRAME') return;
						e.preventDefault();
						startDrag(card, e.clientX, e.clientY);
					});
				});

				document.addEventListener('mousemove', (e: MouseEvent) => {
					if (dragCard) {
						e.preventDefault();
						moveDrag(e.clientX, e.clientY);
					}
				});

				document.addEventListener('mouseup', endDrag);

				// Touch events
				cards.forEach(card => {
					card.addEventListener('touchstart', (e: TouchEvent) => {
						if ((e.target as HTMLElement).tagName === 'IFRAME') return;
						const touch = e.touches[0];
						startDrag(card, touch.clientX, touch.clientY);
					}, { passive: true });
				});

				document.addEventListener('touchmove', (e: TouchEvent) => {
					if (dragCard) {
						e.preventDefault();
						const touch = e.touches[0];
						moveDrag(touch.clientX, touch.clientY);
					}
				}, { passive: false });

				document.addEventListener('touchend', endDrag);
			})();

			/* ── Scroll reveal animation ────────────────────── */
			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('revealed');
						revealObserver.unobserve(entry.target);
					}
				});
			}, { threshold: 0.08 });

			document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

			/* ── Mouse-tracking dot particles (GLOBAL) ────── */
			interface Dot {
				x: number; y: number;
				size: number;
				color: string;
				vx: number; vy: number;
				life: number; maxLife: number;
			}

			const canvas = document.getElementById('dot-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;
			const COLORS = ['#e74c3c', '#3498db', '#2ecc71', '#f39c12', '#9b59b6', '#1abc9c'];
			const dots: Dot[] = [];

			function resize() {
				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;
			}
			resize();
			window.addEventListener('resize', resize);

			window.addEventListener('mousemove', (e: MouseEvent) => {
				for (let i = 0; i < 2; i++) {
					const size = 4 + Math.random() * 5;
					dots.push({
						x: e.clientX + (Math.random() - 0.5) * 20,
						y: e.clientY + (Math.random() - 0.5) * 20,
						size,
						color: COLORS[Math.floor(Math.random() * COLORS.length)],
						vx: (Math.random() - 0.5) * 1.2,
						vy: (Math.random() - 0.5) * 1.2 - 0.5,
						life: 0,
						maxLife: 60 + Math.random() * 60,
					});
				}
			});

			function animateDots() {
				ctx.clearRect(0, 0, canvas.width, canvas.height);
				for (let i = dots.length - 1; i >= 0; i--) {
					const d = dots[i];
					d.x += d.vx;
					d.y += d.vy;
					d.life++;
					const alpha = 1 - d.life / d.maxLife;
					if (alpha <= 0) { dots.splice(i, 1); continue; }
					ctx.globalAlpha = alpha;
					ctx.fillStyle = d.color;
					ctx.fillRect(d.x - d.size / 2, d.y - d.size / 2, d.size, d.size);
				}
				ctx.globalAlpha = 1;
				requestAnimationFrame(animateDots);
			}
			animateDots();

			/* ── Floating nav show/hide on scroll ──────── */
			const floatingNav = document.getElementById('floating-nav')!;
			const heroSection = document.getElementById('home')!;

			const heroObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					floatingNav.classList.toggle('visible', !entry.isIntersecting);
				});
			}, { threshold: 0.1 });
			heroObserver.observe(heroSection);

			/* ── Floating nav active state ─────────────── */
			const floatingLinks = document.querySelectorAll<HTMLAnchorElement>('.floating-nav a');
			const floatingObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const id = entry.target.id;
						floatingLinks.forEach(link => {
							link.classList.toggle('active', link.getAttribute('href') === '#' + id);
						});
					}
				});
			}, { rootMargin: '-30% 0px -50% 0px' });

			document.querySelectorAll('.ide__scroll-area [id]').forEach(el => floatingObserver.observe(el));
		</script>
	</body>
</html>

