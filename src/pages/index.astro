		</div>

		<footer class="footer">
			<p>© {year} Naman Miglani. Built with Astro.</p>
		</footer>

		<script>
			const output = document.getElementById('terminal-output');
			const form = document.getElementById('terminal-form');
			const input = document.getElementById('terminal-cmd');
			const shortcuts = document.querySelectorAll('[data-cmd]');
			const apiOutput = document.getElementById('api-output');
			const apiButtons = document.querySelectorAll('[data-response]');

			const commands = {
				'cd ./about': '#about',
				'cd ./experience': '#experience',
				'cd ./projects': '#projects',
				'cd ./contact': '#contact',
				'open resume.pdf': '/resume.pdf'
			};

			const apiResponses = {
				contact: {
					status: 201,
					message: 'Contact received',
					data: {
						name: 'Recruiter Name',
						email: 'recruiter@company.com',
						company: 'Company Inc.',
						timestamp: new Date().toISOString()
					}
				},
				project: {
					status: 200,
					message: 'Project demo ready',
					data: {
						project: 'MLB Scoreboard Extension',
						users: 350,
						installs: 1200,
						latency_ms: 120
					}
				},
				resume: {
					status: 302,
					message: 'Redirecting to resume.pdf',
					data: { url: '/resume.pdf' }
				}
			};

			const writeLine = (text, cls = '') => {
				const line = document.createElement('p');
				if (cls) line.classList.add(cls);
				line.textContent = text;
				output.appendChild(line);
				output.scrollTop = output.scrollHeight;
			};

			const runCommand = (cmd) => {
				const trimmed = cmd.trim();
				if (!trimmed) return;
				writeLine(`naman@portfolio:~$ ${trimmed}`);
				if (commands[trimmed]) {
					if (trimmed.startsWith('open')) {
						window.open(commands[trimmed], '_blank');
						writeLine('Opening resume.pdf...');
						return;
					}
					const target = document.querySelector(commands[trimmed]);
					if (target) {
						target.scrollIntoView({ behavior: 'smooth', block: 'start' });
						writeLine(`Navigated to ${commands[trimmed]}`);
					}
				} else if (trimmed === 'help') {
					writeLine('Available commands: cd ./about, cd ./experience, cd ./projects, cd ./contact, open resume.pdf');
				} else {
					writeLine('Command not found. Type help for options.', 'muted');
				}
			};

			form.addEventListener('submit', (event) => {
				event.preventDefault();
				runCommand(input.value);
				input.value = '';
			});

			shortcuts.forEach((btn) =>
				btn.addEventListener('click', () => {
					runCommand(btn.dataset.cmd || '');
				})
			);

			const renderResponse = (type) => {
				const payload = apiResponses[type];
				if (!payload) return;
				apiOutput.textContent = JSON.stringify(payload, null, 2);
			};

			apiButtons.forEach((btn) =>
				btn.addEventListener('click', () => renderResponse(btn.dataset.response))
			);

			renderResponse('contact');
		</script>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--bg: #f7f7fb;
		--surface: #ffffff;
		--surface-alt: #f0f2f7;
		--text: #141824;
		--muted: #586174;
		--accent: #2b6bf3;
		--accent-soft: rgba(43, 107, 243, 0.12);
		--border: rgba(20, 24, 36, 0.08);
		--shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
		--radius-lg: 24px;
		--radius-md: 16px;
		--radius-sm: 12px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: "SF Pro Display", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Inter",
			"Segoe UI", sans-serif;
		background: radial-gradient(circle at top, #eef2ff 0%, #f7f7fb 55%, #ffffff 100%);
		color: var(--text);
		line-height: 1.6;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.page {
		max-width: 1200px;
		margin: 0 auto;
		padding: 48px 24px 80px;
		display: flex;
		flex-direction: column;
		gap: 48px;
	}

	.hero {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 32px;
		align-items: start;
	}

	.hero__copy h1 {
		font-size: clamp(2.6rem, 4vw, 3.6rem);
		margin-bottom: 12px;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.75rem;
		color: var(--muted);
		margin-bottom: 16px;
	}

	.subtitle {
		font-size: 1.1rem;
		color: var(--muted);
		max-width: 520px;
	}

	.hero__cta {
		display: flex;
		gap: 12px;
		margin: 24px 0 16px;
		flex-wrap: wrap;
	}

	.hero__links {
		display: flex;
		gap: 12px;
		align-items: center;
		color: var(--muted);
		flex-wrap: wrap;
	}

	.button {
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--text);
		padding: 10px 18px;
		border-radius: 999px;
		font-weight: 600;
		box-shadow: 0 10px 20px rgba(15, 23, 42, 0.06);
	}

	.button.primary {
		background: var(--accent);
		color: #fff;
		border-color: transparent;
	}

	.hero__panel {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.terminal,
	.status-card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
	}

	.terminal__title {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 12px 16px;
		border-bottom: 1px solid var(--border);
		font-size: 0.85rem;
		color: var(--muted);
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		display: inline-block;
	}

	.dot.red {
		background: #ff5f56;
	}

	.dot.yellow {
		background: #ffbd2e;
	}

	.dot.green {
		background: #27c93f;
	}

	.terminal__body {
		padding: 16px;
		max-height: 220px;
		overflow-y: auto;
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.85rem;
	}

	.prompt {
		color: #3d7eff;
		font-weight: 600;
		margin-right: 6px;
	}

	.terminal__input {
		display: flex;
		gap: 8px;
		align-items: center;
		padding: 12px 16px 16px;
		border-top: 1px solid var(--border);
	}

	.terminal__input input {
		flex: 1;
		border: none;
		background: transparent;
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.9rem;
		color: var(--text);
		outline: none;
	}

	.terminal__shortcuts {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		padding: 0 16px 16px;
	}

	.terminal__shortcuts button {
		border: 1px solid var(--border);
		background: var(--surface-alt);
		border-radius: 999px;
		padding: 6px 12px;
		font-size: 0.75rem;
		cursor: pointer;
	}

	.status-card {
		padding: 18px;
	}

	.status-card h3 {
		margin-bottom: 10px;
	}

	.status-card ul {
		padding-left: 18px;
		color: var(--muted);
	}

	.ide {
		display: grid;
		grid-template-columns: minmax(200px, 230px) 1fr;
		gap: 0;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow);
	}

	.ide__sidebar {
		background: #f3f4f8;
		padding: 20px;
		border-right: 1px solid var(--border);
	}

	.ide__title {
		font-size: 0.75rem;
		letter-spacing: 0.15em;
		color: var(--muted);
		margin-bottom: 16px;
	}

	.ide__sidebar ul {
		list-style: none;
		font-size: 0.9rem;
		color: var(--text);
	}

	.folder {
		font-weight: 600;
		margin-bottom: 8px;
	}

	.file {
		color: var(--muted);
		margin-bottom: 6px;
	}

	.indent {
		padding-left: 16px;
	}

	.ide__main {
		display: flex;
		flex-direction: column;
	}

	.ide__tabs {
		display: flex;
		gap: 8px;
		padding: 12px 16px;
		background: var(--surface-alt);
		border-bottom: 1px solid var(--border);
		flex-wrap: wrap;
	}

	.tab {
		padding: 6px 12px;
		border-radius: 10px;
		background: transparent;
		color: var(--muted);
		font-size: 0.85rem;
	}

	.tab.active {
		background: #fff;
		color: var(--text);
		box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 20px;
		padding: 24px;
		background: #fff;
	}

	.card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		padding: 20px;
		box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
	}

	.card h2 {
		margin-bottom: 12px;
	}

	.card h3 {
		margin: 10px 0 4px;
	}

	.span-2 {
		grid-column: span 2;
	}

	.muted {
		color: var(--muted);
	}

	.pill-group {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 12px;
	}

	.pill-group span {
		background: var(--accent-soft);
		color: var(--accent);
		border-radius: 999px;
		padding: 6px 12px;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.timeline ul,
	.projects ul {
		padding-left: 18px;
		color: var(--muted);
	}

	.projects {
		display: grid;
		gap: 16px;
	}

	.playground {
		display: grid;
		gap: 12px;
	}

	.playground__controls {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.playground__controls button {
		border: 1px solid var(--border);
		background: var(--surface-alt);
		border-radius: 10px;
		padding: 8px 12px;
		font-size: 0.8rem;
		cursor: pointer;
	}

	.playground__output {
		background: #0f172a;
		color: #e2e8f0;
		padding: 16px;
		border-radius: 12px;
		font-size: 0.8rem;
		min-height: 160px;
		overflow-x: auto;
	}

	.contact-form {
		display: grid;
		gap: 12px;
	}

	.form-row {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 12px;
	}

	.contact-form input,
	.contact-form textarea {
		width: 100%;
