<style>
	:root {
		--text: #1a1a1a;
		--muted: #666;
		--accent: #1a1a1a;
		--accent-soft: rgba(26, 26, 26, 0.07);
		--border: rgba(0, 0, 0, 0.08);
		--surface: #ffffff;
		--surface-alt: #f5f5f7;
		--shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
		--radius-lg: 20px;
		--radius-md: 14px;
		--radius-sm: 10px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		background: #ffffff;
		color: var(--text);
		line-height: 1.65;
		font-size: 15px;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	/* ── Canvas overlay ──────────────────────────── */
	#dot-canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 10;
	}

	/* ── Hero ────────────────────────────────────── */
	.hero {
		position: relative;
		width: 100%;
		height: 100vh;
		min-height: 520px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		background: #ffffff;
	}

	/* Animated gradient blobs */
	.gradient-blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.55;
		pointer-events: none;
		animation: blobFloat 10s ease-in-out infinite alternate;
	}

	.blob-1 {
		width: 480px;
		height: 480px;
		background: radial-gradient(circle, #ffd6e0 0%, transparent 70%);
		top: -80px;
		left: -100px;
		animation-duration: 12s;
	}

	.blob-2 {
		width: 360px;
		height: 360px;
		background: radial-gradient(circle, #d6f0ff 0%, transparent 70%);
		top: 40px;
		right: -60px;
		animation-duration: 9s;
		animation-delay: -3s;
	}

	.blob-3 {
		width: 420px;
		height: 420px;
		background: radial-gradient(circle, #e8d6ff 0%, transparent 70%);
		bottom: -60px;
		right: 120px;
		animation-duration: 11s;
		animation-delay: -5s;
	}

	.blob-4 {
		width: 320px;
		height: 320px;
		background: radial-gradient(circle, #d6ffe8 0%, transparent 70%);
		bottom: -40px;
		left: 180px;
		animation-duration: 13s;
		animation-delay: -2s;
	}

	@keyframes blobFloat {
		0% { transform: translate(0, 0) scale(1); }
		100% { transform: translate(30px, 20px) scale(1.07); }
	}

	.hero__content {
		position: relative;
		z-index: 2;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
	}

	.hero__name {
		font-size: clamp(2.8rem, 6vw, 4.4rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--text);
		line-height: 1.1;
	}

	.hero__tagline {
		font-size: clamp(0.9rem, 1.8vw, 1.1rem);
		color: var(--muted);
		font-weight: 400;
		max-width: 520px;
	}

	.highlight-blue { color: #2563eb; font-family: 'Inter', sans-serif; }
	.highlight-green { color: #16a34a; }
	.highlight-red { color: #dc2626; }

	.hero__nav {
		display: flex;
